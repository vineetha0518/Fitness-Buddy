# ============================================================
#  Fitness Buddy � Environment Configuration
#  Copy this file to .env and fill in your real credentials.
#  NEVER commit .env to version control.
# ============================================================

# ------ IBM Watsonx.ai Credentials ------
IBM_API_KEY=
IBM_WATSONX_URL=
IBM_PROJECT_ID=
# ------ IBM Granite Model ID ------
# Options: ibm/granite-13b-chat-v2  |  ibm/granite-3-8b-instruct
IBM_MODEL_ID=ibm/granite-3-8b-instruct

# ------ Flask Configuration ------
FLASK_SECRET_KEY=change_this_to_a_random_secret_key_123!
FLASK_ENV=development
FLASK_DEBUG=True

# ------ App Configuration ------
APP_NAME=Fitness Buddy
APP_VERSION=1.0.0
